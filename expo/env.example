# Saver Insurance - Environment Variables
# Copy this file to .env and fill in your values

# ============================================
# ADMIN & SECURITY
# ============================================

# Admin token for tRPC protected operations
# Generate a strong random string: openssl rand -hex 32
ADMIN_TOKEN=your-secure-admin-token-here

# Client-side admin token (must match ADMIN_TOKEN for admin panel access)
EXPO_PUBLIC_ADMIN_TOKEN=your-secure-admin-token-here

# Basic Auth credentials for /api/admin/* endpoints (CSV export, stats)
# Used by Hono middleware for HTTP Basic Auth
ADMIN_BASIC_USER=admin
ADMIN_BASIC_PASS=your-secure-admin-password-here

# ============================================
# FEATURE FLAGS
# ============================================

# Auto-create QuoteRequest when lead reaches READY_TO_QUOTE
# Set to "true" to enable automatic quote request creation
AUTO_CREATE_QUOTE_REQUEST=false

# ============================================
# WEBHOOKS (for n8n / external integrations)
# ============================================

# n8n webhook URL for lead events
N8N_WEBHOOK_URL=https://your-n8n-instance.com/webhook/saver-lead

# Optional: HMAC secret for webhook signature verification
N8N_WEBHOOK_SECRET=your-webhook-secret-here

# ============================================
# WHATSAPP
# ============================================

# Official WhatsApp Business number
WHATSAPP_NUMBER=+19567738844

# ============================================
# DATABASE - SUPABASE (REQUIRED FOR PRODUCTION)
# ============================================

# Supabase project URL (from Project Settings > API)
SUPABASE_URL=https://your-project.supabase.co

# Supabase service role key (from Project Settings > API > service_role)
# WARNING: Keep this secret! Never expose in client-side code
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Optional: Direct PostgreSQL connection (for migrations)
# DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# ============================================
# EXPO / APP CONFIG
# ============================================

# EXPO_PUBLIC_API_URL=https://your-api-domain.com
